/**
 * 获取日志总数
 */
function getTotalLogsCount($filters = []) {
    $dbFile = DATA_DIR . '/logs.db';
    
    if (!file_exists($dbFile)) {
        return 0;
    }
    
    try {
        $db = new SQLite3($dbFile);
        $db->busyTimeout(5000);
        
        // 构建 WHERE 条件
        $where = [];
        $params = [];
        
        if (!empty($filters['feature'])) {
            $where[] = "feature = :feature";
            $params[':feature'] = $filters['feature'];
        }
        
        if (!empty($filters['spider_type'])) {
            $where[] = "spider_type = :spider_type";
            $params[':spider_type'] = $filters['spider_type'];
        }
        
        $whereClause = !empty($where) ? 'WHERE ' . implode(' AND ', $where) : '';
        
        // 查询总数
        $sql = "SELECT COUNT(*) as total FROM redirect_logs $whereClause";
        $stmt = $db->prepare($sql);
        
        foreach ($params as $key => $value) {
            $stmt->bindValue($key, $value);
        }
        
        $result = $stmt->execute();
        $row = $result->fetchArray(SQLITE3_ASSOC);
        
        $db->close();
        return $row['total'] ?? 0;
        
    } catch (Exception $e) {
        error_log('SQLite count failed: ' . $e->getMessage());
        return 0;
    }
}

/**
 * 获取统计数据
 */
function getLogStats() {
    $dbFile = DATA_DIR . '/logs.db';
    
    if (!file_exists($dbFile)) {
        return [];
    }
    
    try {
        $db = new SQLite3($dbFile);
        
        // 按功能统计（今日）
        $todayStart = strtotime('today');
        $result = $db->query("
            SELECT feature, COUNT(*) as count 
            FROM redirect_logs 
            WHERE timestamp >= $todayStart
            GROUP BY feature
        ");
        
        $stats = [];
        while ($row = $result->fetchArray(SQLITE3_ASSOC)) {
            $stats[$row['feature']] = $row['count'];
        }
        
        $db->close();
        return $stats;
        
    } catch (Exception $e) {
        return [];
    }
}

/**
 * 获取爬虫显示名称
 */
function getSpiderDisplayName($type, $subtype = '') {
    if ($type === 'baidu_spider') {
        switch ($subtype) {
            case 'baidu_render': return '百度渲染';
            case 'baidu_mobile': return '百度移动';
            case 'baidu_pc': return '百度PC';
            default: return '百度蜘蛛';
        }
    }
    
    $names = [
        'google_spider' => '谷歌蜘蛛',
        'sogou_spider' => '搜狗蜘蛛',
        'so_spider' => '360蜘蛛',
        'bing_spider' => '必应蜘蛛',
        'other_spider' => '其他蜘蛛',
        'normal_user' => '普通用户',
    ];
    
    return $names[$type] ?? '未知';
}

/**
 * 计算相对时间
 */
function getRelativeTime($timestamp) {
    $diff = time() - $timestamp;
    
    if ($diff < 60) {
        return "刚刚 ({$diff}秒前)";
    } elseif ($diff < 3600) {
        return floor($diff / 60) . "分钟前";
    } elseif ($diff < 86400) {
        return floor($diff / 3600) . "小时前";
    } else {
        return date('m-d H:i', $timestamp);
    }
}

