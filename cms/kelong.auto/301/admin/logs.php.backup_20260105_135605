/**
 * 获取最新日志
 */
function getRecentLogs($limit = 100, $offset = 0, $filters = []) {
    $dbFile = DATA_DIR . '/logs.db';
    
    if (!file_exists($dbFile)) {
        return [];
    }
    
    try {
        $db = new SQLite3($dbFile);
        $db->busyTimeout(5000);
        
        // 构建 WHERE 条件
        $where = [];
        $params = [];
        
        if (!empty($filters['feature'])) {
            $where[] = "feature = :feature";
            $params[':feature'] = $filters['feature'];
        }
        
        if (!empty($filters['spider_type'])) {
            $where[] = "spider_type = :spider_type";
            $params[':spider_type'] = $filters['spider_type'];
        }
        
        $whereClause = !empty($where) ? 'WHERE ' . implode(' AND ', $where) : '';
        
        // 查询日志
        $sql = "
            SELECT * FROM redirect_logs 
            $whereClause
            ORDER BY timestamp DESC 
            LIMIT :limit OFFSET :offset
        ";
        
        $stmt = $db->prepare($sql);
        
        foreach ($params as $key => $value) {
            $stmt->bindValue($key, $value);
        }
        
        $stmt->bindValue(':limit', $limit, SQLITE3_INTEGER);
        $stmt->bindValue(':offset', $offset, SQLITE3_INTEGER);
        
        $result = $stmt->execute();
        
        $logs = [];
        while ($row = $result->fetchArray(SQLITE3_ASSOC)) {
            $logs[] = $row;
        }
        
        $db->close();
        return $logs;
        
    } catch (Exception $e) {
        error_log('SQLite query failed: ' . $e->getMessage());
        return [];
    }
}

