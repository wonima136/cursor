<script>
let autoRefreshInterval = null;
let currentFilter = 'all';
let currentTaskFilter = ''; // 当前任务筛选
let currentPage = 1;
let pageSize = 100;
let totalLogs = <?php echo count($logs); ?>;
let allLogs = []; // 存储所有日志
let lastLogId = <?php echo !empty($logs) ? $logs[0]['id'] : 0; ?>;
let isOnFirstPage = true; // 是否在第一页

// 自动刷新
function startAutoRefresh() {
    autoRefreshInterval = setInterval(() => {
        loadLatestLogs();
    }, 5000);
}

// 停止自动刷新
function stopAutoRefresh() {
    if (autoRefreshInterval) {
        clearInterval(autoRefreshInterval);
        autoRefreshInterval = null;
    }
}

// 切换自动刷新
function toggleAutoRefresh() {
    const indicator = document.getElementById('refreshIndicator');
    const btn = event.target;
    
    if (autoRefreshInterval) {
        stopAutoRefresh();
        indicator.classList.add('paused');
        indicator.querySelector('span').textContent = '已暂停';
        btn.textContent = '开始';
    } else {
        startAutoRefresh();
        indicator.classList.remove('paused');
        indicator.querySelector('span').textContent = '自动刷新 (5秒)';
        btn.textContent = '暂停';
    }
}

// 加载最新日志（仅在第一页且未筛选时）
function loadLatestLogs() {
    // 如果不在第一页，自动暂停刷新
    if (!isOnFirstPage) {
        stopAutoRefresh();
        const indicator = document.getElementById('refreshIndicator');
        const btn = indicator.nextElementSibling.nextElementSibling;
        indicator.classList.add('paused');
        indicator.querySelector('span').textContent = '已暂停（翻页中）';
        btn.textContent = '开始';
        return;
    }
    
    fetch('logs.php', {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: 'ajax=1&action=get_logs&limit=10&offset=0&feature=' + (currentFilter === 'all' ? '' : currentFilter)
    })
    .then(res => res.json())
    .then(data => {
        if (data.success && data.logs.length > 0) {
            const tbody = document.getElementById('logsTableBody');
            const firstLog = data.logs[0];
            
            // 如果有新日志
            if (firstLog.id > lastLogId) {
                // 插入新日志到表格顶部
                data.logs.reverse().forEach(log => {
                    if (log.id > lastLogId) {
                        const row = createLogRow(log, true);
                        tbody.insertAdjacentHTML('afterbegin', row);
                        
                        // 如果超过100条，删除最后一条
                        const rows = tbody.querySelectorAll('tr');
                        if (rows.length > pageSize) {
                            rows[rows.length - 1].remove();
                        }
                    }
                });
                
                lastLogId = firstLog.id;
                totalLogs += data.logs.length;
                
                // 更新统计
                updateStats();
                updatePaginationInfo();
            }
        }
    });
}

// 创建日志表格行
function createLogRow(log, isNew = false) {
    const spiderName = getSpiderName(log.spider_type, log.spider_subtype);
    const relativeTime = getRelativeTime(log.timestamp);
    const taskName = log.task_name || '';
    
    let taskCell = '';
    if (taskName) {
        taskCell = `<span class="badge badge-task" onclick="filterByTask('${taskName.replace(/'/g, "\\'")}')" title="点击筛选此任务">${taskName}</span>`;
    } else {
        taskCell = '<span style="color: var(--text-muted); font-size: 12px;">-</span>';
    }
    
    return `
        <tr class="${isNew ? 'new' : ''}" data-feature="${log.feature}" data-task="${taskName}">
            <td class="time-cell">
                <span class="relative-time">${relativeTime}</span>
                <span class="absolute-time">${log.datetime}</span>
            </td>
            <td class="ip-cell">${log.ip}</td>
            <td>
                <span class="badge badge-spider ${spiderName}">${spiderName}</span>
            </td>
            <td>
                <span class="badge badge-redirect">${log.redirect_type}</span>
            </td>
            <td>
                <span class="badge badge-feature ${log.feature}">${log.feature}</span>
            </td>
            <td>${taskCell}</td>
            <td class="url-cell" title="${log.source_url}">${log.source_url}</td>
            <td class="url-cell" title="${log.target_url}">${log.target_url}</td>
        </tr>
    `;
}

// 获取爬虫名称
function getSpiderName(type, subtype) {
    if (type === 'baidu_spider') {
        if (subtype === 'baidu_render') return '百度渲染';
        if (subtype === 'baidu_mobile') return '百度移动';
        if (subtype === 'baidu_pc') return '百度PC';
        return '百度蜘蛛';
    }
    const names = {
        'google_spider': '谷歌蜘蛛',
        'sogou_spider': '搜狗蜘蛛',
        'so_spider': '360蜘蛛',
        'bing_spider': '必应蜘蛛',
        'other_spider': '其他蜘蛛',
        'normal_user': '普通用户'
    };
    return names[type] || '未知';
}

// 计算相对时间
function getRelativeTime(timestamp) {
    const diff = Math.floor(Date.now() / 1000) - timestamp;
    
    if (diff < 60) return `刚刚 (${diff}秒前)`;
    if (diff < 3600) return `${Math.floor(diff / 60)}分钟前`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}小时前`;
    
    const date = new Date(timestamp * 1000);
    return `${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')} ${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}`;
}

// 更新统计
function updateStats() {
    fetch('logs.php', {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: 'ajax=1&action=get_stats'
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            // 计算总数
            let totalCount = 0;
            for (const count of Object.values(data.stats)) {
                totalCount += count;
            }
            
            // 更新统计栏
            const statsBar = document.querySelector('.stats-bar');
            const currentActive = document.querySelector('.stat-badge.active')?.dataset.feature || 'all';
            
            statsBar.innerHTML = `
                <div class="stat-badge ${currentActive === 'all' ? 'active' : ''}" data-feature="all" onclick="filterByFeature('all')">
                    全部记录: <strong>${totalCount}</strong>
                </div>
            `;
            
            for (const [feature, count] of Object.entries(data.stats)) {
                const isActive = currentActive === feature ? 'active' : '';
                statsBar.innerHTML += `
                    <div class="stat-badge ${feature} ${isActive}" data-feature="${feature}" onclick="filterByFeature('${feature}')">
                        ${feature}: <strong>${count}</strong>
                    </div>
                `;
            }
        }
    });
}

// 统一的筛选应用函数
function applyFilter(filter) {
    currentFilter = filter;
    
    // 更新筛选按钮状态
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    document.querySelector(`.filter-btn[data-filter="${filter}"]`)?.classList.add('active');
    
    // 更新统计徽章状态
    document.querySelectorAll('.stat-badge').forEach(b => b.classList.remove('active'));
    document.querySelector(`.stat-badge[data-feature="${filter}"]`)?.classList.add('active');
    
    // 显示/隐藏日志行
    let visibleCount = 0;
    const tbody = document.getElementById('logsTableBody');
    if (tbody) {
        tbody.querySelectorAll('tr').forEach(row => {
            if (filter === 'all' || row.dataset.feature === filter) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });
    }
    
    // 重置到第一页
    currentPage = 1;
    isOnFirstPage = true;
    updatePaginationInfo();
    
    // 更新导出按钮文字
    updateExportButton();
}

// 通过功能模块筛选（统计徽章点击）
function filterByFeature(feature) {
    currentTaskFilter = ''; // 清除任务筛选
    applyFilter(feature);
    
    // 更新任务徽章状态
    document.querySelectorAll('.badge-task').forEach(b => b.classList.remove('active'));
    
    // 平滑滚动到日志列表
    const table = document.querySelector('.logs-table-wrapper');
    if (table) {
        table.scrollIntoView({ 
            behavior: 'smooth', 
            block: 'start' 
        });
    }
}

// 通过任务筛选
function filterByTask(taskName) {
    currentTaskFilter = taskName;
    currentFilter = 'all'; // 清除功能筛选
    
    // 更新筛选按钮状态
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    document.querySelector('.filter-btn[data-filter="all"]')?.classList.add('active');
    
    // 更新统计徽章状态
    document.querySelectorAll('.stat-badge').forEach(b => b.classList.remove('active'));
    document.querySelector('.stat-badge[data-feature="all"]')?.classList.add('active');
    
    // 更新任务徽章状态
    document.querySelectorAll('.badge-task').forEach(b => {
        if (b.textContent === taskName) {
            b.classList.add('active');
        } else {
            b.classList.remove('active');
        }
    });
    
    // 显示/隐藏日志行
    let visibleCount = 0;
    const tbody = document.getElementById('logsTableBody');
    if (tbody) {
        tbody.querySelectorAll('tr').forEach(row => {
            const rowTask = row.dataset.task || '';
            if (rowTask === taskName) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });
    }
    
    // 显示筛选提示
    showTaskFilterHint(taskName, visibleCount);
    
    // 重置到第一页
    currentPage = 1;
    isOnFirstPage = true;
    updatePaginationInfo();
    
    // 更新导出按钮文字
    updateExportButton();
    
    // 平滑滚动到日志列表
    const table = document.querySelector('.logs-table-wrapper');
    if (table) {
        table.scrollIntoView({ 
            behavior: 'smooth', 
            block: 'start' 
        });
    }
}

// 显示任务筛选提示
function showTaskFilterHint(taskName, count) {
    // 移除旧提示
    const oldHint = document.querySelector('.task-filter-hint');
    if (oldHint) oldHint.remove();
    
    // 创建新提示
    const hint = document.createElement('div');
    hint.className = 'task-filter-hint';
    hint.innerHTML = `
        <span>🔍 正在筛选任务：<strong>${taskName}</strong> (${count} 条记录)</span>
        <button onclick="clearTaskFilter()" style="margin-left: 12px; padding: 4px 12px; background: rgba(255,255,255,0.1); border: none; border-radius: 4px; color: var(--text); cursor: pointer;">
            ✕ 清除筛选
        </button>
    `;
    
    // 插入到控制栏下方
    const controlsBar = document.querySelector('.controls-bar');
    controlsBar.insertAdjacentElement('afterend', hint);
}

// 清除任务筛选
function clearTaskFilter() {
    currentTaskFilter = '';
    
    // 移除提示
    const hint = document.querySelector('.task-filter-hint');
    if (hint) hint.remove();
    
    // 移除任务徽章激活状态
    document.querySelectorAll('.badge-task').forEach(b => b.classList.remove('active'));
    
    // 重新应用功能筛选
    applyFilter(currentFilter);
    
    // 更新导出按钮文字
    updateExportButton();
}

// 更新导出按钮文字
function updateExportButton() {
    const btn = document.getElementById('exportBtn');
    if (!btn) return;
    
    let text = '📤 导出';
    
    if (currentTaskFilter) {
        text += ` ${currentTaskFilter}`;
    } else if (currentFilter !== 'all') {
        text += ` ${currentFilter}`;
    } else {
        text += ' 全部';
    }
    
    btn.textContent = text;
    btn.title = `导出${currentTaskFilter ? '任务「' + currentTaskFilter + '」' : (currentFilter !== 'all' ? '「' + currentFilter + '」' : '全部')}的数据`;
}

// 导出CSV（根据当前筛选条件）
function exportCSV() {
    // 构建表单数据
    const formData = new FormData();
    formData.append('ajax', '1');
    formData.append('action', 'export_csv');
    
    // 添加筛选条件
    if (currentFilter !== 'all') {
        formData.append('feature', currentFilter);
    }
    if (currentTaskFilter) {
        formData.append('task_name', currentTaskFilter);
    }
    
    // 创建隐藏表单提交
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = 'logs.php';
    form.target = '_blank';
    
    for (const [key, value] of formData.entries()) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = key;
        input.value = value;
        form.appendChild(input);
    }
    
    document.body.appendChild(form);
    form.submit();
    document.body.removeChild(form);
    
    // 显示提示
    showExportHint();
}

// 显示导出提示
function showExportHint() {
    let message = '正在导出';
    
    if (currentTaskFilter) {
        message += ` 任务「${currentTaskFilter}」`;
    } else if (currentFilter !== 'all') {
        message += ` 「${currentFilter}」`;
    } else {
        message += ' 全部';
    }
    
    message += ' 的日志数据...';
    
    // 创建提示
    const hint = document.createElement('div');
    hint.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 12px 20px;
        background: rgba(16, 185, 129, 0.9);
        color: white;
        border-radius: 8px;
        font-size: 14px;
        z-index: 9999;
        animation: fadeInOut 3s;
    `;
    hint.textContent = message;
    
    document.body.appendChild(hint);
    
    setTimeout(() => {
        hint.remove();
    }, 3000);
}

// 上一页
function prevPage() {
    if (currentPage > 1) {
        currentPage--;
        isOnFirstPage = (currentPage === 1);
        loadPage(currentPage);
        
        // 如果离开第一页，暂停自动刷新
        if (!isOnFirstPage && autoRefreshInterval) {
            stopAutoRefresh();
            const indicator = document.getElementById('refreshIndicator');
            const btn = indicator.nextElementSibling.nextElementSibling;
            indicator.classList.add('paused');
            indicator.querySelector('span').textContent = '已暂停（翻页中）';
            btn.textContent = '开始';
        }
    }
}

// 下一页
function nextPage() {
    const totalPages = Math.ceil(totalLogs / pageSize);
    if (currentPage < totalPages) {
        currentPage++;
        isOnFirstPage = false;
        loadPage(currentPage);
        
        // 离开第一页，暂停自动刷新
        if (autoRefreshInterval) {
            stopAutoRefresh();
            const indicator = document.getElementById('refreshIndicator');
            const btn = indicator.nextElementSibling.nextElementSibling;
            indicator.classList.add('paused');
            indicator.querySelector('span').textContent = '已暂停（翻页中）';
            btn.textContent = '开始';
        }
    }
}

// 跳转到指定页
function goToPage(page) {
    currentPage = page;
    isOnFirstPage = (page === 1);
    loadPage(page);
    
    // 如果离开第一页，暂停自动刷新
    if (!isOnFirstPage && autoRefreshInterval) {
        stopAutoRefresh();
        const indicator = document.getElementById('refreshIndicator');
        const btn = indicator.nextElementSibling.nextElementSibling;
        indicator.classList.add('paused');
        indicator.querySelector('span').textContent = '已暂停（翻页中）';
        btn.textContent = '开始';
    }
    
    // 如果回到第一页，提示可以恢复自动刷新
    if (isOnFirstPage && !autoRefreshInterval) {
        const indicator = document.getElementById('refreshIndicator');
        indicator.querySelector('span').textContent = '已暂停（点击开始恢复）';
    }
}

// 加载指定页的数据
function loadPage(page) {
    const offset = (page - 1) * pageSize;
    
    fetch('logs.php', {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: `ajax=1&action=get_logs&limit=${pageSize}&offset=${offset}&feature=` + (currentFilter === 'all' ? '' : currentFilter)
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            const tbody = document.getElementById('logsTableBody');
            tbody.innerHTML = '';
            
            data.logs.forEach(log => {
                tbody.innerHTML += createLogRow(log);
            });
            
            // 更新总数
            if (data.total !== undefined) {
                totalLogs = data.total;
            }
            
            updatePaginationInfo();
        }
    });
}

// 更新分页信息
function updatePaginationInfo() {
    const totalPages = Math.ceil(totalLogs / pageSize);
    const start = (currentPage - 1) * pageSize + 1;
    const end = Math.min(currentPage * pageSize, totalLogs);
    
    document.getElementById('pageStart').textContent = start;
    document.getElementById('pageEnd').textContent = end;
    document.getElementById('totalLogs').textContent = totalLogs;
    
    // 更新按钮状态
    document.getElementById('prevBtn').disabled = (currentPage === 1);
    document.getElementById('nextBtn').disabled = (currentPage >= totalPages);
    
    // 生成页码
    const pageNumbers = document.getElementById('pageNumbers');
    pageNumbers.innerHTML = '';
    
    // 显示页码（最多显示5个）
    let startPage = Math.max(1, currentPage - 2);
    let endPage = Math.min(totalPages, startPage + 4);
    
    if (endPage - startPage < 4) {
        startPage = Math.max(1, endPage - 4);
    }
    
    for (let i = startPage; i <= endPage; i++) {
        const pageBtn = document.createElement('div');
        pageBtn.className = 'page-number' + (i === currentPage ? ' active' : '');
        pageBtn.textContent = i;
        pageBtn.onclick = () => goToPage(i);
        pageNumbers.appendChild(pageBtn);
    }
}

// 初始化分页
updatePaginationInfo();

// 启动自动刷新
startAutoRefresh();
</script>

